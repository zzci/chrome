# tint2 minimal panel: launchers + taskbar + IME indicator + clock

# Panel
panel_items = LTEC
panel_size = 100% 32
panel_margin = 0 0
panel_padding = 4 0 4
panel_position = bottom center horizontal
panel_background_id = 1
wm_menu = 0
panel_dock = 0
panel_layer = bottom

# Backgrounds
rounded = 0
border_width = 0
background_color = #2b2b2b 90
border_color = #000000 0

rounded = 0
border_width = 0
background_color = #444444 60
border_color = #000000 0

# Launcher
launcher_padding = 4 4 4
launcher_background_id = 0
launcher_icon_size = 22
launcher_icon_theme_override = 0
startup_notifications = 0
launcher_item_app = /build/share/applications/terminal.desktop
launcher_item_app = /build/share/applications/chrome.desktop

# Taskbar
taskbar_mode = single_desktop
taskbar_padding = 6 0 6
taskbar_background_id = 0
task_align = left
task_padding = 6 2 6
task_maximum_size = 240 26
task_centered = 0
task_text = 1
task_icon = 1
task_font_color = #ffffff 90
task_active_font_color = #ffffff 100
task_active_background_id = 2
urgent_nb_of_blink = 0

# Executor — fcitx5 IME indicator. Click toggles activate/inactive.
execp = new
execp_command = /build/bin/fcitx5_indicator
execp_interval = 1
execp_continuous = 0
execp_has_icon = 0
execp_font_color = #ffffff 95
execp_padding = 8 0
execp_background_id = 0
execp_lclick_command = fcitx5-remote -t

# Clock
time1_format = %Y-%m-%d %H:%M
time1_font = sans 11
clock_font_color = #ffffff 95
clock_padding = 6 0
clock_background_id = 0

# Tooltip / mouse / autohide off
tooltip_show_timeout = 0.5
tooltip_hide_timeout = 0.1
mouse_left = toggle_iconify
mouse_middle = none
mouse_right = close
mouse_scroll_up = none
mouse_scroll_down = none
autohide = 0
