#!/bin/sh

# Single-shot chrome launch. Keep-alive (for CDP) is handled by start_cdp.

RUN_USER="zzci"
RUN_HOME="/home/zzci"

/build/bin/wait_for_x

DBUS_ADDR="$(cat /tmp/.dbus-session-bus 2>/dev/null || true)"

rm -f "$RUN_HOME/.config/google-chrome/Singleton"* 2>/dev/null || true

exec su -s /bin/sh "$RUN_USER" -c "DISPLAY=:1 \
    DBUS_SESSION_BUS_ADDRESS='$DBUS_ADDR' \
    HOME='$RUN_HOME' USER='$RUN_USER' LOGNAME='$RUN_USER' \
    exec google-chrome-stable \
    --no-first-run \
    --start-maximized \
    --window-size=1920,1080 \
    --window-position=0,0 \
    --remote-debugging-port=19222 \
    --disable-gpu \
    --disable-software-rasterizer \
    --disable-dev-shm-usage \
    --disable-background-networking \
    --disable-sync \
    --disable-translate \
    --disable-default-apps \
    --disable-component-update \
    --disable-domain-reliability \
    --disable-client-side-phishing-detection \
    --disable-hang-monitor \
    --disable-popup-blocking \
    --disable-prompt-on-repost \
    --disable-breakpad \
    --metrics-recording-only \
    --no-default-browser-check \
    --mute-audio"
