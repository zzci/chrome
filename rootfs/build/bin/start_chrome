#!/bin/sh

# Single-shot chrome launch. Keep-alive (for CDP) is handled by start_cdp.

: "${RUN_USER:=zzci}"
: "${RUN_HOME:=/home/$RUN_USER}"

# Wait briefly for the X session to publish the DBus address (only present
# in vnc mode; xvfb mode has no DBus and the loop times out harmlessly).
DBUS_ADDR=""
for _ in $(seq 1 20); do
    if [ -s /tmp/.dbus-session-bus ]; then
        DBUS_ADDR=$(cat /tmp/.dbus-session-bus)
        break
    fi
    sleep 0.3
done

rm -f "$RUN_HOME/.config/chrome/Singleton"* 2>/dev/null || true

exec su -s /bin/sh "$RUN_USER" -c "
    export DISPLAY=:1 \
        DBUS_SESSION_BUS_ADDRESS='$DBUS_ADDR' \
        HOME='$RUN_HOME' USER='$RUN_USER' LOGNAME='$RUN_USER' \
        GTK_IM_MODULE=fcitx QT_IM_MODULE=fcitx XMODIFIERS=@im=fcitx
    /build/bin/wait_for_x || exit 1
    exec google-chrome-stable \
    --no-first-run \
    --user-data-dir=\$HOME/.config/chrome \
    --remote-debugging-port=19222 \
    --disable-gpu \
    --disable-software-rasterizer \
    --disable-dev-shm-usage \
    --disable-background-networking \
    --disable-sync \
    --disable-translate \
    --disable-default-apps \
    --disable-component-update \
    --disable-domain-reliability \
    --disable-client-side-phishing-detection \
    --disable-hang-monitor \
    --disable-popup-blocking \
    --disable-prompt-on-repost \
    --disable-breakpad \
    --metrics-recording-only \
    --no-default-browser-check \
    --mute-audio"
