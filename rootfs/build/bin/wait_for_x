#!/bin/sh

# Block until the given X display is reachable. Used by services that
# attach to the xsession (panel, chrome, ...) so they can autostart in
# parallel with vnc and just wait for it to come up.

display="${1:-:1}"
for _ in $(seq 1 60); do
    xset -display "$display" q >/dev/null 2>&1 && exit 0
    sleep 0.5
done
echo "wait_for_x: $display not ready after 30s" >&2
exit 1
