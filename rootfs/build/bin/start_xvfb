#!/bin/sh

# Lightweight headless X server. Use as an alternative to the vnc service
# when you only need chrome + cdp (no web desktop).
# Switch with: -e ZSRV_DESKTOP=xvfb

set -e

: "${RUN_USER:=zzci}"

# Privileged setup as root: reconcile uid/gid + clear stale X locks
/build/bin/init_user
rm -f /tmp/.X1-lock /tmp/.X11-unix/X1 2>/dev/null || true

# Drop to $RUN_USER so Xvfb runs as the same user that chrome and fcitx5
# use, matching the vnc service's user model.
exec runuser -u "$RUN_USER" -- Xvfb :1 -screen 0 1920x1080x24 -nolisten tcp -ac
