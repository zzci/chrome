#!/bin/sh

# Interactive chrome launcher used by the tint2 panel button.
# tint2 runs as the X session user so we can exec chrome directly.
# Stale singleton locks are cleared so a click after a crash still produces
# a window.

DATA_DIR="$HOME/.config/chrome"
rm -f "$DATA_DIR/Singleton"* 2>/dev/null || true

# Same user-data-dir as the CDP service, so when CDP is on the click opens
# a new window in the existing chrome (profile shared) instead of spawning
# a second instance. When CDP is off, this is just a fresh chrome.
exec /usr/bin/google-chrome-stable \
    --user-data-dir="$DATA_DIR" \
    --no-first-run \
    --no-default-browser-check \
    "$@"
