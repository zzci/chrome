#!/bin/sh

# Interactive chrome launcher used by the tint2 panel button.
# tint2 runs as the X session user so we can exec chrome directly.
#
# Do NOT remove SingletonLock here: when chrome is already running on this
# user-data-dir, the lock is what makes a second invocation forward its
# args (URL etc.) to the existing instance instead of spawning a competing
# one. Chrome itself reaps the lock if its owner PID is dead.

exec /usr/bin/google-chrome-stable \
    --user-data-dir="$HOME/.config/chrome" \
    --no-first-run \
    --no-default-browser-check \
    "$@"
